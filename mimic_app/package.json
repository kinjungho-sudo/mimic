{
  "name": "mimic-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "test": "npm run verify:quality",
    "verify:recorder-profile": "node scripts/verify-recorder-profile.mjs",
    "verify:synthetic-capture-ui": "node scripts/verify-synthetic-capture-ui.mjs",
    "verify:synthetic-finish-navigation": "node scripts/verify-synthetic-finish-navigation.mjs",
    "verify:live-guide": "node scripts/verify-live-guide-fail-closed.mjs",
    "verify:quality": "node scripts/verify-capture-fallback.js && node scripts/verify-regenerate-content.js && node --loader ./scripts/ts-path-loader.mjs scripts/verify-rewrite-purpose-quality.js && node --loader ./scripts/ts-path-loader.mjs scripts/verify-follow-config.js",
    "verify:desktop": "node ../mimic_desktop/native-host/scripts/smoke-native-host.js && node ../mimic_desktop/native-host/scripts/test-native-import.js && node ../mimic_desktop/native-host/scripts/test-scribe-controls.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@blocknote/code-block": "^0.51.4",
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@types/dompurify": "^3.0.5",
    "docx": "^9.7.1",
    "dompurify": "^3.4.7",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "openai": "^6.39.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
